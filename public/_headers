# Performance optimization headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  # Enable browser features for performance
  Permissions-Policy: autoplay=(), geolocation=(), microphone=(), camera=()
  # HSTS — load over HTTPS for 2 years once the user has visited once.
  # `preload` opts the site into the browser preload list (irreversible —
  # submit to https://hstspreload.org only after auditing every subdomain).
  Strict-Transport-Security: max-age=63072000; includeSubDomains
  # CSP for the dashboard SPA. Looser than the published-landing-page CSP
  # because the dashboard is a complex React app with inline-styled shadcn
  # components ('unsafe-inline' for styles) and inline event handlers from
  # React ('unsafe-inline' for scripts). Tighten further once every third-
  # party widget the dashboard embeds (Stripe, Meta Pixel, notifications)
  # has been audited and given an explicit nonce / hash.
  #
  # `connect-src` includes:
  #   - self (same-origin)
  #   - *.supabase.co for DB / auth / edge functions
  #   - wss://*.supabase.co for realtime channels
  #   - api.openrouter.ai + generativelanguage.googleapis.com for the AI
  #     config (when configured server-side in the future this can be
  #     removed from the client policy)
  #   - api.stripe.com for billing redirects (when Stripe is wired in)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://connect.facebook.net https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.openrouter.ai https://generativelanguage.googleapis.com https://api.stripe.com https://www.google-analytics.com https://www.facebook.com; frame-src 'self' https://js.stripe.com https://hooks.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self' https://*.supabase.co https://hooks.stripe.com

# Cache static assets with content hash aggressively
/assets/*
  Cache-Control: public, max-age=31536000, s-maxage=31536000, immutable, stale-while-revalidate=86400

# Cache images
/*.png
  Cache-Control: public, max-age=31536000, immutable, stale-while-revalidate=86400
/*.jpg
  Cache-Control: public, max-age=31536000, immutable, stale-while-revalidate=86400
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable, stale-while-revalidate=86400
/*.webp
  Cache-Control: public, max-age=31536000, immutable, stale-while-revalidate=86400
/*.avif
  Cache-Control: public, max-age=31536000, immutable, stale-while-revalidate=86400
/*.svg
  Cache-Control: public, max-age=31536000, immutable, stale-while-revalidate=86400
/*.bin
  Cache-Control: public, max-age=31536000, immutable, stale-while-revalidate=86400

# Cache fonts
/*.woff2
  Cache-Control: public, max-age=31536000, immutable, stale-while-revalidate=86400
/*.woff
  Cache-Control: public, max-age=31536000, immutable, stale-while-revalidate=86400

# HTML - short cache with revalidation for landing page performance
/*.html
  Cache-Control: public, max-age=300, s-maxage=300, stale-while-revalidate=86400

# Service Worker - never cache
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate
  Cache-Control: post-check=0, pre-check=0

# Critical performance headers
/
  Cross-Origin-Resource-Policy: cross-origin
  X-Content-Type-Options: nosniff
