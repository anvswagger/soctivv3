# ============================================================================
# Soctiv v3 — Environment Variables (TEMPLATE ONLY)
# ============================================================================
# DO NOT commit real values to this file.
# Copy this file to .env.local (gitignored) and fill in the real values:
#     cp .env.example .env.local
#
# Where secrets are stored:
#   - Local dev      → .env.local   (gitignored)
#   - Cloudflare Pages → Project Settings → Environment Variables
#   - Supabase Edge Functions → `supabase functions deploy --no-verify-jwt <name>`
#                                then `supabase secrets set KEY=value`
#
# Anything prefixed VITE_ is bundled into the client. NEVER put service_role
# keys, OAuth secrets, or AI provider keys into VITE_* variables.
# ============================================================================

# --- Supabase (client-side) -----------------------------------------------
# Get these from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- App build metadata ----------------------------------------------------
VITE_APP_VERSION=0.0.0
VITE_COMMIT_SHA=local

# --- Sentry (optional) -----------------------------------------------------
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_PROFILES_SAMPLE_RATE=0.03

# --- Web Push (VAPID public key) ------------------------------------------
VITE_WEB_PUSH_PUBLIC_KEY=

# --- Feature flags ---------------------------------------------------------
VITE_ENABLE_PUSH_DEV=false
VITE_ENABLE_PUBLIC_FUNCTIONS_DEV=false

# --- AI provider keys (optional; required for AI features in dev) ----------
# OpenRouter: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=

# --- Edge / shared runtime (set in Supabase function env, not Vite) --------
APP_RELEASE=
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
CORS_ALLOW_LOCALHOST=true

# --- capi-proxy (Meta Conversion API server-side relay) --------------------
# CRITICAL: required for browser → capi-proxy CORS preflight to succeed on
# cross-origin deploys (Netlify → Supabase is cross-origin). Without this,
# every browser POST to /functions/v1/capi-proxy fails the CORS preflight
# and no Lead/Purchase/ViewContent events reach Meta CAPI. Published landing
# pages are served from the soctiv.ly apex (the /p/<pageId>/ fallback) and
# from *.soctiv.ly subdomains, so allow both.
ALLOWED_ORIGIN=https://soctiv.ly,https://*.soctiv.ly

# --- capi-proxy shared secret (HMAC over pixel events) --------------------
# Generated once per deployment and injected into both the Supabase edge
# function env and the publish-landing-page edge function (which embeds
# a derived per-pixel signature into the published page's pixel.js).
# Without this, anyone with the capiUrl can POST fake Lead/Purchase events
# attributed to your pixel — see the CAPI auth runbook for rotation.
CAPI_SHARED_SECRET=change-me-to-a-32-byte-random-string

# --- Supabase Edge Function env (set via `supabase secrets set`) ----------
# The edge functions read these directly. Do NOT prefix with VITE_.
# SUPABASE_URL=                                  (auto-set by Supabase)
# SUPABASE_ANON_KEY=                             (auto-set by Supabase)
# SUPABASE_SERVICE_ROLE_KEY=                     (auto-set by Supabase)
# ERSAAL_API_KEY=
# OPENROUTER_API_KEY=
# REMINDER_TEMPLATE_ID_24H=appointment-reminder-24h
# REMINDER_TEMPLATE_ID_6H=
# REMINDER_TEMPLATE_ID_1H=appointment-reminder-1h
# APP_SETTINGS_SUPABASE_URL=
# APP_SETTINGS_SERVICE_ROLE_KEY=
