# Frontend runtime
# Cloudflare Pages: Set these in your Cloudflare dashboard -> Pages -> Settings -> Environment Variables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_APP_VERSION=
VITE_COMMIT_SHA=
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_PROFILES_SAMPLE_RATE=0.03
VITE_WEB_PUSH_PUBLIC_KEY=
VITE_ENABLE_PUSH_DEV=false
VITE_ENABLE_PUBLIC_FUNCTIONS_DEV=false

# Edge/shared runtime (documented here for local parity)
APP_RELEASE=
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
CORS_ALLOW_LOCALHOST=true

